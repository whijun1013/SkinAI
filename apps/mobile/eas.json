{
  "cli": {
    "version": ">= 14.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "http://localhost:8000",
        "OAUTH_BASE_URL": "http://localhost:8000"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "env": {
        "API_BASE_URL": "https://api.skinai.nuvo.com",
        "OAUTH_BASE_URL": "https://api.skinai.nuvo.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
