ENV=dev
LOG_LEVEL=INFO
MAX_IMAGE_SIZE=2048

# MedGemma local/H100 worker probe
MONGO_URL=
MONGO_DB_NAME=
HF_TOKEN=
MEDGEMMA_MODEL_NAME=google/medgemma-4b-it
MEDGEMMA_OUTPUT_CONTAINER=medgemma-probe-outputs
MEDGEMMA_QUEUE_ENABLED=false
MEDGEMMA_QUEUE_SIGNED_URL_EXPIRY_HOURS=72
MEDGEMMA_WORKER_POLL_SECONDS=10
MEDGEMMA_WORKER_MAX_ATTEMPTS=3
MEDGEMMA_STALE_REQUEUE_INTERVAL_MINUTES=60
MEDGEMMA_USE_FAST_PROCESSOR=true
MEDGEMMA_TORCH_DTYPE=bf16
MEDGEMMA_MAX_IMAGE_SIDE=768
MEDGEMMA_MAX_TOKENS=600

# MedGemma primary visual analysis
MEDGEMMA_PRIMARY_VISUAL_MIN_CONFIDENCE=medium
MEDGEMMA_INCLUDE_REVIEW_IN_PRIMARY=false
